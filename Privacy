<!DOCTYPE html>
<html lang="en">
<head>
  <meta charset="UTF-8" />
  <meta name="viewport" content="width=device-width, initial-scale=1.0" />
  <title>Privacy Policy | MaJa Ofertas</title>

  <style>
    *{
      margin:0;
      padding:0;
      box-sizing:border-box;
      font-family: Arial, Helvetica, sans-serif;
    }

    body{
      background: linear-gradient(135deg, #0f172a, #1e293b);
      color:#f8fafc;
      min-height:100vh;
      display:flex;
      justify-content:center;
      align-items:center;
      padding:30px;
    }

    .container{
      width:100%;
      max-width:800px;
      background:rgba(255,255,255,0.08);
      border:1px solid rgba(255,255,255,0.15);
      backdrop-filter: blur(12px);
      border-radius:24px;
      padding:45px;
      box-shadow:0 10px 40px rgba(0,0,0,0.35);
    }

    h1{
      font-size:40px;
      margin-bottom:25px;
      color:#ffffff;
    }

    p{
      font-size:18px;
      line-height:1.9;
      color:#e2e8f0;
      margin-bottom:20px;
    }

    .highlight{
      color:#38bdf8;
      font-weight:bold;
    }

    .footer{
      margin-top:35px;
      padding-top:20px;
      border-top:1px solid rgba(255,255,255,0.15);
      color:#94a3b8;
      font-size:14px;
    }

    @media(max-width:768px){

      .container{
        padding:28px;
      }

      h1{
        font-size:30px;
      }

      p{
        font-size:16px;
      }

    }
  </style>
</head>

<body>

  <div class="container">

    <h1>Privacy Policy</h1>

    <p>
      <span class="highlight">MaJa Ofertas</span> does not collect personal data from users.
    </p>

    <p>
      We use the TikTok API only to publish content to our own account.
    </p>

    <p>
      No user data is stored, shared, or sold to third parties.
    </p>

    <div class="footer">
      © 2026 MaJa Ofertas. All rights reserved.
    </div>

  </div>

</body>
</html>
